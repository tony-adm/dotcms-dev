<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Analytics Dashboard - PowerAdmin</title>

  <!-- Favicons -->
  <link href="${DOT_THEME_PATH}assets/img/favicon.png" rel="icon">
  <link href="${DOT_THEME_PATH}assets/img/apple-touch-icon.png" rel="apple-touch-icon">

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  <!-- Vendor CSS Files -->
  <link href="${DOT_THEME_PATH}assets/vendor/bootstrap/css/bootstrap.min.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/remixicon/remixicon.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/fontawesome-free/css/all.min.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/phosphor-icons/phosphor-icons.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/lucide-icons/lucide.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/simple-datatables/style.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/quill/quill.snow.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/quill/quill.bubble.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/choices.js/choices.min.css" rel="stylesheet">
  <link href="${DOT_THEME_PATH}assets/vendor/flatpickr/flatpickr.min.css" rel="stylesheet">

  <!-- Template Main CSS File -->
  <link href="${DOT_THEME_PATH}assets/css/main.css" rel="stylesheet">
</head>

<body>
  #dotParse("//application/vtl/poweradmin-theme/header.vtl")

  <!-- Sidebar -->
  <aside class="sidebar">
    <!-- Icon Strip -->
    <div class="sidebar-strip">
      <div class="sidebar-strip-logo">
        <a href="/index">
          <img src="${DOT_THEME_PATH}assets/img/logo.webp" alt="PowerAdmin">
        </a>
      </div>
      <nav class="sidebar-strip-nav">
        <ul class="strip-menu">
           <li>
            <button class="strip-item active" data-panel="dashboards" data-bs-toggle="tooltip" data-bs-placement="right" data-bs-title="Dashboards">
              <i class="ph ph-squares-four"></i>
            </button>
          </li>
        </ul>
      </nav>
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main">
    <div class="main-content page-dashboard-analytics">
      <!-- Page Header -->
      <div class="page-header">
        <h1 class="page-title">Analytics Dashboard</h1>
        <nav class="breadcrumb">
          <a href="/index" class="breadcrumb-item">Home</a>
          <span class="breadcrumb-item active">Analytics</span>
        </nav>
      </div>

      <!-- Main Container for Editable Content -->
      ## Container: Main Content
      #dedit()

      <!-- Stats Row (Static for now, can be made dynamic later) -->
      <div class="dashboard-grid dashboard-grid-4">
        <div class="card widget-stat">
          <div class="widget-stat-header">
            <div>
              <div class="widget-stat-value">248,532</div>
              <div class="widget-stat-label">Total Visitors</div>
            </div>
            <div class="widget-stat-icon primary">
              <i class="bi bi-people"></i>
            </div>
          </div>
        </div>
      </div>

    </div>

    #dotParse("//application/vtl/poweradmin-theme/footer.vtl")
  </main>

  <!-- Vendor JS Files -->
  <script src="${DOT_THEME_PATH}assets/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
  <script src="${DOT_THEME_PATH}assets/vendor/apexcharts/apexcharts.min.js"></script>
  <script src="${DOT_THEME_PATH}assets/vendor/chart.js/chart.umd.js"></script>
  <script src="${DOT_THEME_PATH}assets/vendor/echarts/echarts.min.js"></script>
  <script src="${DOT_THEME_PATH}assets/vendor/simple-datatables/simple-datatables.js"></script>
  <script src="${DOT_THEME_PATH}assets/vendor/quill/quill.js"></script>
  <script src="${DOT_THEME_PATH}assets/vendor/tinymce/tinymce.min.js"></script>
  <script src="${DOT_THEME_PATH}assets/vendor/choices.js/choices.min.js"></script>
  <script src="${DOT_THEME_PATH}assets/vendor/flatpickr/flatpickr.min.js"></script>

  <!-- Template Main JS Files -->
  <script src="${DOT_THEME_PATH}assets/js/theme.js"></script>
  <script src="${DOT_THEME_PATH}assets/js/main.js"></script>

</body>
</html>
